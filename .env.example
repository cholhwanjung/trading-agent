# 이 파일을 .env로 복사해 실제 값 기입 (.env는 gitignore됨 — 커밋 금지)
# 발급 방법: 각 브로커 개발자 포털 참고

# --- 크립토 (Binance Spot Testnet) ---
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# --- 미국 주식 (Alpaca Paper) ---
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET=

# --- 한국 주식 (KIS 모의투자) ---
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT=

# --- KIS 실전 (실자금 — KR 국내 + US 해외주식 겸용, 통합증거금) ---
# 실전 앱키로 국내(KR)와 해외(US) 모두 주문. 계좌는 8자리-2자리(예: 12345678-01).
# US 는 사전 USD 환전 필요(어댑터는 USD 예수금만 현금으로 계상).
KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT=

# --- 실계좌 안전 게이트 (실자금 주문 경로 전용) ---
# 1회/일일 주문 명목 상한(USD) — 비율 리스크 레이어가 못 막는 절대 금액 보완.
# kill switch: `touch data/state/KILL_SWITCH` 로 전 실주문 즉시 정지(파일 삭제로 해제).
LIVE_MAX_ORDER_USD=200
LIVE_MAX_DAILY_USD=500
# 실패/거부/MDD 서킷 push 웹훅 (Slack 또는 Discord incoming webhook URL). 비우면 로그만.
ALERT_WEBHOOK_URL=

# --- LLM (멀티 프로바이더 — 하나 이상 설정) ---
# tier 지정: "provider:model". provider ∈ anthropic|openai|gemini|deepseek|openrouter|xai|ollama
LLM_SMART=anthropic:claude-sonnet-5
LLM_FAST=anthropic:claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1  # 로컬 모델 (키 불필요)

# --- 데이터 피드 ---
FRED_API_KEY=
DART_API_KEY=

# --- Chat Gateway (비우면 인증 없음 — 로컬 단독) ---
INTERACTION_API_TOKEN=
